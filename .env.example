# API-Keys für die Layer-3-Messungen.
# Kopiere diese Datei nach ".env" und trage deine Keys ein.
# Die echte ".env" ist via .gitignore vom Git ausgeschlossen (Keys NIE committen).
#
# 6 Keys für 9 Endpunkte (Deepgram/OpenAI/Azure teilen sich je einen Key für 2 Dienste):

DEEPGRAM_API_KEY=        # Deepgram STT (Nova-3) + TTS (Aura-2)
REVAI_ACCESS_TOKEN=      # Rev.ai STT
AZURE_SPEECH_KEY=        # Azure STT + TTS (Italy North)
OPENAI_API_KEY=          # OpenAI LLM (gpt-4o-mini) + TTS (tts-1)
GROQ_API_KEY=            # Groq LLM (llama-3.1-8b-instant)
MISTRAL_API_KEY=         # Mistral LLM (mistral-small-2603)
